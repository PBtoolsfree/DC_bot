# ============================================================
# Discord Management Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ----------------------------------------------------------
# Discord Bot
# ----------------------------------------------------------
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_DEV_GUILD_ID=
# Comma-separated list of Discord user IDs who are bot owners
BOT_OWNER_IDS=

# ----------------------------------------------------------
# PostgreSQL Database
# ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/discord_bot
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ----------------------------------------------------------
# Celery (Background Tasks)
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ----------------------------------------------------------
# API Server (FastAPI)
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ----------------------------------------------------------
# Dashboard (Next.js)
# ----------------------------------------------------------
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------
# Discord OAuth2
# ----------------------------------------------------------
OAUTH2_CLIENT_ID=your_oauth2_client_id
OAUTH2_CLIENT_SECRET=your_oauth2_client_secret
OAUTH2_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ----------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------------------------------------
# AI Provider
# ----------------------------------------------------------
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# ----------------------------------------------------------
# Sentry (Error Tracking — Optional)
# ----------------------------------------------------------
SENTRY_DSN=
