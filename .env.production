# ============================================================
# Production Environment Configuration
# ============================================================
# SECURITY: Generate all secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Copy to .env before running: docker compose up -d
# ============================================================

# ----------------------------------------------------------
# Discord Bot
# ----------------------------------------------------------
DISCORD_TOKEN=<your_production_bot_token>
DISCORD_DEV_GUILD_ID=
BOT_OWNER_IDS=<comma_separated_owner_ids>

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_USER=discord_bot
POSTGRES_PASSWORD=<generate_with_secrets_token_hex_32>
DATABASE_URL=postgresql+asyncpg://discord_bot:<same_password>@postgres:5432/discord_bot
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ----------------------------------------------------------
# Celery
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----------------------------------------------------------
# API Server
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ----------------------------------------------------------
# Dashboard
# ----------------------------------------------------------
DASHBOARD_URL=https://your-domain.com

# ----------------------------------------------------------
# Discord OAuth2
# ----------------------------------------------------------
DISCORD_CLIENT_ID=<your_oauth2_client_id>
DISCORD_CLIENT_SECRET=<your_oauth2_client_secret>
DISCORD_REDIRECT_URI=https://your-domain.com/auth/callback

# ----------------------------------------------------------
# JWT — MUST change this. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------
JWT_SECRET_KEY=<generate_with_secrets_token_hex_32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------------------------------------
# AI Provider (optional)
# ----------------------------------------------------------
AI_PROVIDER=none
GEMINI_API_KEY=
OPENAI_API_KEY=

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------------------------------------------------
# Environment
# ----------------------------------------------------------
ENVIRONMENT=production
DEBUG=false

# ----------------------------------------------------------
# Sentry (optional but recommended)
# ----------------------------------------------------------
SENTRY_DSN=
